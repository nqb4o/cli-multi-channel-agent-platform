# ── Daytona sandbox provider ────────────────────────────────────────────────
# Leave empty to use in-memory fake mode (fine for local dev / tests).
DAYTONA_API_KEY=
DAYTONA_API_URL=
DAYTONA_TARGET=
SANDBOX_IMAGE=ubuntu:24.04

# ── Telegram channel ─────────────────────────────────────────────────────────
# Get token from @BotFather. WEBHOOK_SECRET is an arbitrary random string you
# choose; it must match what you register with Telegram's setWebhook call.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Your personal Telegram chat ID — used by the demo-pipeline to send a test message.
USER_CHAT_ID=

# ── Database ─────────────────────────────────────────────────────────────────
# POSTGRES_DSN  — used by gateway at runtime
# DB_DSN        — used by the migrate binary (same value, different var name)
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/agent_platform
DB_DSN=postgresql://postgres:postgres@localhost:5432/agent_platform

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Gateway ──────────────────────────────────────────────────────────────────
GATEWAY_HTTP_ADDR=0.0.0.0:8080
# 32-byte hex key for AES-GCM encryption of channel config in DB.
# Generate: openssl rand -hex 32
DB_ENCRYPTION_KEY=
# Static bearer token for /admin/* endpoints. Keep secret in production.
ADMIN_TOKEN=devtoken
# HS256 secret for user JWT tokens. Keep secret in production.
USER_JWT_SECRET=dev-secret
# Set to 1 to allow /auth/login with magic_code "BYPASS". Demo / local only.
BYPASS_LOGIN=1

# ── Orchestrator ─────────────────────────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:8081
ORCHESTRATOR_PORT=8081

# ── Provider CLIs (project-local npm install) ────────────────────────────────
CODEX_BIN=.tools/node_modules/.bin/codex
GEMINI_BIN=.tools/node_modules/.bin/gemini
CLAUDE_BIN=.tools/node_modules/.bin/claude

# ── Observability (optional) ─────────────────────────────────────────────────
# Point at your OTEL collector. Leave empty to disable export.
OTEL_EXPORTER_OTLP_ENDPOINT=
