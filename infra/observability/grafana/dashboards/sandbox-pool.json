{
  "title": "Sandbox Pool",
  "uid": "platform-sandbox-pool",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["platform", "sandbox"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Sandbox cold-start latency p50 / p95 / p99",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(sandbox_cold_start_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sandbox_cold_start_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(sandbox_cold_start_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cold vs warm starts / minute",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (cold) (rate(sandbox_cold_start_seconds_count[1m]))",
          "legendFormat": "cold={{cold}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cold-start p95 (target: < 5s)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sandbox_cold_start_seconds_bucket{cold=\"true\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "MCP tool calls / minute (by tool)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 8, "y": 8, "w": 16, "h": 8},
      "targets": [
        {
          "expr": "sum by (tool) (rate(mcp_tool_call_total[1m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    }
  ]
}
