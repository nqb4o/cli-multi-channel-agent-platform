{
  "title": "Provider Health",
  "uid": "platform-provider-health",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["platform", "providers", "health"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Agent run failure rate (by provider)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (provider) (rate(agent_runs_total{outcome!=\"ok\"}[5m])) / sum by (provider) (rate(agent_runs_total[5m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CLI turn latency p99 (by provider)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (provider, le) (rate(cli_turn_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 3,
      "type": "table",
      "title": "Per-provider success vs error counts (last 1h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (provider, outcome) (increase(agent_runs_total[1h]))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Fallback activations / minute (provider.fallback span attribute)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (provider) (rate(agent_runs_total{provider_fallback=\"true\"}[1m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    }
  ]
}
