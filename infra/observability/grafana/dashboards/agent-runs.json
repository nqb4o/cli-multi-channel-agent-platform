{
  "title": "Agent Runs",
  "uid": "platform-agent-runs",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["platform", "agents"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "provider",
        "label": "Provider",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(agent_runs_total, provider)",
        "includeAll": true,
        "multi": true,
        "current": {"text": "All", "value": "$__all"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Agent runs / minute (by provider)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (provider) (rate(agent_runs_total{provider=~\"$provider\"}[1m]))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Agent run latency p50 / p95 / p99",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_run_latency_seconds_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_run_latency_seconds_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(agent_run_latency_seconds_bucket{provider=~\"$provider\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate (last 5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
      "targets": [
        {
          "expr": "sum(rate(agent_runs_total{outcome=\"error\",provider=~\"$provider\"}[5m])) / sum(rate(agent_runs_total{provider=~\"$provider\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.05},
              {"color": "red", "value": 0.2}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "CLI turn latency p95 (by provider)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 6, "y": 8, "w": 18, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(cli_turn_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    }
  ]
}
